JWT_SECRET=replace-with-a-long-random-secret
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# PostgreSQL. On Railway set this to ${{Postgres.DATABASE_URL}} as a reference variable.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/flow_bot
DATABASE_POOL_MAX=10
DATABASE_CONNECT_TIMEOUT_MS=10000

# Anonymous workflow execution limits (backend only).
ANONYMOUS_RUN_LIMIT=10
ANONYMOUS_RUN_WINDOW_MS=60000
ANONYMOUS_FLOW_MAX_BYTES=100000
ANONYMOUS_FLOW_MAX_NODES=50
ANONYMOUS_FLOW_MAX_EDGES=100
ANONYMOUS_ALLOWED_MODELS=gpt-4o-mini

# OAuth 2.0 Web Client ID; backend và frontend phải dùng cùng một giá trị.
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# Backend-only LLM configuration. Never prefix secrets with VITE_.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VECTOR_STORE_ID=
# OPENAI_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_MS=60000
# Optional pricing overrides for custom endpoints or negotiated pricing.
# Known OpenAI models use standard model pricing automatically.
# OPENAI_INPUT_COST_PER_MILLION=
# OPENAI_CACHED_INPUT_COST_PER_MILLION=
# OPENAI_OUTPUT_COST_PER_MILLION=

# Tavily web search (backend only).
TAVILY_API_KEY=
# TAVILY_BASE_URL=https://api.tavily.com
SEARCH_TIMEOUT_MS=15000

# Optional observability. Workflow execution remains successful if unavailable.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_TIMEOUT_MS=2000

# Chỉ cần khi API chạy khác origin với frontend trong production.
# VITE_API_URL=https://api.example.com
