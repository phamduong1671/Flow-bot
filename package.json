{
  "name": "flow-bot-builder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "eslint .",
    "format": "prettier \"**/*.{js,jsx,ts,tsx,css,html,json,md,yml,yaml}\" --write",
    "format:check": "prettier \"**/*.{js,jsx,ts,tsx,css,html,json,md,yml,yaml}\" --check",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^8.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "postcss": "^8.4.49",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.16",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  }
}
